# Environment Variables Template
# Copy this file to .env and fill in your values

# OpenRouter API Key (get free key at: https://openrouter.ai/)
# AI features won't work without this key
OPENROUTER_API_KEY=your_api_key_here

# UNDP HDR Data API Key (get key at: https://hdrdata.org)
# Used for Human Development Index scores
HDR_API_KEY=your_hdr_api_key_here
